# ===============================
# ORION AI ASSISTANT - TEMPLATE .env
# ===============================

# --- ZORUNLU SİSTEM AYARLARI ---
COMPOSE_PROJECT_NAME=orion-backend
ENV=dev  # (dev/prod)

# Yerel bilgisayarınızdaki tam yolu buraya yazın
CONFIG_FILE=config/ai_config.json

# --- API ANAHTARLARI (Kendi anahtarlarınızı girin) ---
GOOGLE_API_KEY=your_google_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# --- VERİTABANI ŞİFRELERİ ---
ARANGO_PASSWORD=your_secure_arango_password
POSTGRES_PASSWORD=your_secure_postgres_password

# --- ORION AI BACKEND (FastAPI + Agent) ---
# Uvicorn'un dinleyeceği sunucu adresi/portu (container veya VM içi bind ayarı)
API_HOST=0.0.0.0
API_PORT=8000
WS_ENABLE_REAL_AGENT=true

# --- MODEL VE AGENT AYARLARI ---
AGENT_MODEL=gemini
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TEMPERATURE=1.0

# --- ADMIN PANEL AYARLARI ---
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3000
ADMIN_TOKEN=your_admin_secret_token
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Dışarıdan erişilecek gerçek backend adresi (admin panel bu URL'e istek atar)
# Local örnek:  http://localhost:8000
# Prod örnek:   https://api.orionai.com
API_BACKEND_URL=http://localhost:8000

# --- OPSİYONEL / GELECEKTEKİ ENTEGRASYONLAR ---
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json