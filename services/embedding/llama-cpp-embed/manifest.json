{
  "id": "llama-cpp-embed",
  "name": "llama.cpp Embedding Server",
  "category": "embedding",
  "description": "Yüksek performanslı, GGUF formatında multimodal embedding sunucusu.",
  "version": "1.0.0",
  "vram_required_gb": 4,
  "parameters": {
    "GPU_LAYERS": {
      "default": 35,
      "label": "GPU Katman Sayısı",
      "min": 0,
      "max": 100,
      "type": "int"
    },
    "CONTEXT_SIZE": {
      "default": 8192,
      "label": "Bağlam Boyutu (Context)",
      "min": 512,
      "max": 128000,
      "type": "int"
    },
    "BATCH_SIZE": {
      "default": 512,
      "label": "Batch Boyutu",
      "min": 8,
      "max": 8192,
      "type": "int"
    },
    "N_PARALLEL": {
      "default": 1,
      "label": "Paralel İstek Sayısı",
      "min": 1,
      "max": 16,
      "type": "int"
    }
  },
  "models_path": "models/",
  "models_catalog": [
    {
      "id": "jina-v5-omni-nano",
      "name": "Jina Embeddings v5 Omni-Nano",
      "folder": "jina-embeddings",
      "description": "Jina AI tarafından geliştirilen çok amaçlı (multimodal) embedding modeli. GGUF formatı.",
      "files": [
        "jina-embeddings-v5-omni-nano-retrieval-F16.gguf"
      ],
      "env": {
        "EXTRA_ARGS": "--pooling last"
      }
    },
    {
      "id": "lco-embedding-omni-7b",
      "name": "LCO Embedding Omni 7B",
      "folder": "LCO-Embedding",
      "description": "LCO (Large Context Omni) Embedding modeli. 7B parametreli, yüksek kapasiteli ve geniş bağlam desteği.",
      "files": [
        "LCO-Embedding-Omni-7B-IQ2_M.gguf"
      ],
      "env": {
        "EXTRA_ARGS": "--pooling last"
      }
    }
  ],
  "supports": [
    "nvidia",
    "amd",
    "cpu"
  ],
  "default_hardware": "nvidia",
  "source": {
    "type": "docker",
    "registry": "ghcr.io",
    "image": "ggml-org/llama.cpp",
    "tags": {
      "nvidia": "server-cuda",
      "amd": "server-rocm",
      "cpu": "server"
    }
  },
  "supported_environments": [
    {
      "id": "llm-nv-cuda",
      "name": "NVIDIA - CUDA (Hızlı)",
      "base_image": "ghcr.io/ggml-org/llama.cpp:server-cuda",
      "hardware": "nvidia"
    },
    {
      "id": "llm-amd-rocm",
      "name": "AMD - ROCm",
      "base_image": "ghcr.io/ggml-org/llama.cpp:server-rocm",
      "hardware": "amd"
    },
    {
      "id": "llm-cpu-only",
      "name": "Sadece CPU (Yavaş)",
      "base_image": "ghcr.io/ggml-org/llama.cpp:server",
      "hardware": "cpu"
    }
  ],
  "compose_files": {
    "nvidia": "docker-compose.nvidia.yml",
    "amd": "docker-compose.amd.yml",
    "cpu": "docker-compose.cpu.yml"
  },
  "api": {
    "style": "openai-compatible",
    "endpoint": "/v1/embeddings"
  },
  "status": "installable"
}