# =============================================================
#  Orion Global Konfigürasyon
#
#  KURAL: Bu dosya tüm servislerin ortak "adres defteri"dir.
#  - Host isimlerini (Docker ağ içi DNS) buradan yönet.
#  - Dış portları (APP_PORT: host makinede açılacak port) buradan yönet.
#  - İç portları (CONTAINER_PORT: konteyner içindeki uygulama portu) buradan yönet.
#
#  Servis-özgü ayarlar (model boyutu, GPU katmanı vb.) için
#  her servisin kendi klasöründeki .env dosyasına bak.
# =============================================================

# --- Docker Ağı ---
# NOT: Bu ağ adının ('orion-network') tüm servislerde (router, hub, vb.) aynı kalması
# servislerin birbirleriyle Docker iç ağı üzerinden (daha hızlı ve güvenli) haberleşebilmesi için önemlidir.
# Zorunlu olmadıkça değiştirmeyin.
ORION_NETWORK=orion-network
DEFAULT_LISTEN_HOST=0.0.0.0
INSTALLER_PORT=7171

# --- LLM Servisi ---
LLM_PROJECT_NAME=orion-llm
LLM_HOST=llama-cpp
LLM_PORT=8085
LLM_CONTAINER_PORT=8080

# --- Text Embedding Servisi ---
EMBEDDING_PROJECT_NAME=orion-embedding
EMBED_HOST=llama-cpp-embed
EMBED_PORT=8086
EMBED_CONTAINER_PORT=8080

# --- TTS Servisi ---
TTS_PROJECT_NAME=orion-tts
TTS_HOST=tts
TTS_PORT=8808
TTS_CONTAINER_PORT=8808

# --- STT Servisi ---
STT_PROJECT_NAME=orion-stt
STT_HOST=stt
STT_PORT=9009
STT_CONTAINER_PORT=9009

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

POSTGRES_HOST=postgres
POSTGRES_PORT=5445
POSTGRES_DB=orion
POSTGRES_USER=orion
POSTGRES_PASSWORD=orion

# --- Orion Hub API ---
HUB_PROJECT_NAME=orion-hub
HUB_HOST=api
HUB_PORT=8909
HUB_CONTAINER_PORT=8909

# --- Orion Hub Worker ---
WORKER_HOST=worker

# --- Load Balancer (Nginx) ---
LB_PORT=8090
NGINX_HOST=lb
NGINX_CONTAINER_PORT=80
API_2_HOST=api-2

# --- Admin API ---
# ADMIN_API_KEY=

# --- Orion Router ---
ROUTER_HOST=router
ROUTER_PORT=20128
ROUTER_CONTAINER_PORT=20128
APP_REFERER=https://orion-ai-assistant.github.io/orion-ai-assistant
APP_TITLE="Orion AI Assistant"
APP_CATEGORIES="personal-agent,cli-agent"
CLI_LANG=en
