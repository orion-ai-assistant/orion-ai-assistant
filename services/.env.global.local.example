# =============================================================
# Orion Global Local Settings Example
# =============================================================

# --- Admin API ---
ADMIN_API_KEY=orionadmin

# --- Orion Router ---
ADMIN_SECRET=orion

# --- CLI Language ---
# System language for CLI and output (e.g. 'en', 'tr')
# If left empty, installer will auto-detect and append it here.
# CLI_LANG=en
