{
  "id": "whisper-stt",
  "name": "Faster Whisper STT",
  "category": "stt",
  "description": "Fast and efficient Speech-to-Text server. OpenAI-compatible API support.",
  "version": "1.10.0",
  "vram_required_gb": 2,
  "parameters": {
    "GPU_DEVICE_IDS": { "type": "gpu_selector", "label": "GPUs to Use", "default": "all" },
    "WHISPER_MODEL": {"default": "base", "label": "Whisper Model"},
    "WHISPER_COMPUTE_TYPE": {"default": "float16", "label": "Compute Type"}
  },
  "supports": ["nvidia", "cpu"],
  "default_hardware": "nvidia",
  "supported_environments": [
    {
      "id": "stt-nv-cuda",
      "name": "NVIDIA - CUDA",
      "base_image": "docker.io/fedirz/faster-whisper-server:latest-cuda",
      "hardware": "nvidia"
    },
    {
      "id": "stt-cpu",
      "name": "CPU Only",
      "base_image": "docker.io/fedirz/faster-whisper-server:latest-cpu",
      "hardware": "cpu"
    }
  ],
  "compose_files": {
    "nvidia": "docker-compose.nvidia.yml",
    "cpu": "docker-compose.cpu.yml"
  },
  "api": {
    "style": "openai-compatible",
    "endpoint": "/v1/audio/transcriptions"
  },
  "status": "disabled"
}
